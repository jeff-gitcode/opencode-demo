@baseUrl = http://localhost:5000

### Register a new user
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "email": "test@test.com",
  "password": "Test123!"
}

### Login - @name stores the response
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "testuser",
  "password": "Test123!"
}

### Extract token from login response (run Login first)
@token = {{login.response.body.token}}

### Get weather forecast with stored token
GET {{baseUrl}}/weatherforecast
Authorization: Bearer {{token}}
